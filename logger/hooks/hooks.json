{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '{timestamp: now | floor} + .' >> .claude-history.jsonl"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '{timestamp: now | floor} + .' >> .claude-history.jsonl"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '{timestamp: now | floor} + .' >> .claude-history.jsonl"
          }
        ]
      }
    ]
  }
}
